{
  "schemaVersion": 1,
  "id": "vanillarice",
  "version": "${version}",

  "name": "Vanilla Rice",
  "description": "This mod adds rice and rice foods in vanilla like fashion! Craft them or find them in the naturals / foods tabs in creative mode :)",
  "authors": [
    "Loomiyaa"
  ],
  "contact": {
    "homepage": "https://github.com/Loomiyaa",
    "sources": "https://github.com/Loomiyaa/VanillaRice"
  },

  "license": "CC BY-SA 4.0",
  "icon": "assets/vanillarice/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "net.loomiyaa.vanillarice.VanillaRice"
    ],
    "client": [
      "net.loomiyaa.vanillarice.VanillaRiceClient"
    ]
  },
  "mixins": [
    "vanillarice.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "~26.1",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
